{
  "permissions": {
    "deny": [
      "Bash(tail -f *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-date-loops.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/scripts/hook-block-never-exists-wait.sh"
          }
        ]
      },
      {
        "matcher": "ScheduleWakeup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-schedule-wakeup.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/tooling/claude-hooks/block-blocking-bash.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/tooling/claude-hooks/post-history.sh"
          }
        ]
      }
    ]
  }
}
