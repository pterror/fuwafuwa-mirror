{
  "permissions": {
    "deny": [
      "Bash(tail -f *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-date-loops.sh"
          }
        ]
      },
      {
        "matcher": "ScheduleWakeup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/block-schedule-wakeup.sh"
          }
        ]
      }
    ]
  }
}
